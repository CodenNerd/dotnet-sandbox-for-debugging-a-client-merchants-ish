<Window x:Class="WebView2.Working.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="WebView2 Working" Height="850" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="8" LastChildFill="True">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Button x:Name="BackButton" Content="Back" Width="70" Margin="0,0,6,0" Click="BackButton_Click" />
                <Button x:Name="ForwardButton" Content="Forward" Width="80" Margin="0,0,6,0" Click="ForwardButton_Click" />
                <Button Content="Reload" Width="80" Margin="0,0,6,0" Click="ReloadButton_Click" />
                <Button Content="Local Test" Width="90" Margin="0,0,6,0" Click="LocalTestButton_Click" />
                <Button Content="DevTools" Width="80" Margin="0,0,6,0" Click="DevToolsButton_Click" />
                <Button Content="Clear Profile" Width="95" Margin="0,0,12,0" Click="ClearProfileButton_Click" />
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="AddressBar" MinWidth="500" VerticalContentAlignment="Center" KeyDown="AddressBar_KeyDown" />
                <Button Content="Go" Width="60" Margin="6,0,0,0" Click="GoButton_Click" />
            </StackPanel>
        </DockPanel>

        <wv2:WebView2 x:Name="Browser" Grid.Row="1" />

        <Grid Grid.Row="2" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                <TextBlock Text="Diagnostic log" FontWeight="Bold" VerticalAlignment="Center" />
                <Button DockPanel.Dock="Right" Content="Copy" Width="70" Margin="6,0,0,0" Click="CopyLogButton_Click" />
                <Button DockPanel.Dock="Right" Content="Open Log Folder" Width="115" Click="OpenLogFolderButton_Click" />
            </DockPanel>
            <TextBox x:Name="LogBox" Grid.Row="1" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12" />
        </Grid>
    </Grid>
</Window>
